
def solve():
    d = deque()
    # Read the number of operations
    for _ in range(int(input())):
        # Split input into method name and optional value
        line = input().split()
        method_name = line[0]
       
        # Check if the method has an argument (like append 1)
        if len(line) > 1:
            val = line[1]
            # Equivalent to d.append(val) or d.appendleft(val)
            getattr(d, method_name)(val)
