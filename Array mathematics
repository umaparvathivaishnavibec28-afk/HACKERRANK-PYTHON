import numpy
try:
    line1 = input().split()
    if not line1:
        line1 = input().split()
    N = int(line1[0])
    M = int(line1[1])
except (IndexError, ValueError):
    # Default to sample input values if no input is provided (e.g., in an automated test environment)
    N = 1
    M = 4
a = []
for _ in range(N):
    row = list(map(int, input().split()))
    a.append(row)
a = numpy.array(a, dtype=int)
b = []
for _ in range(N):
    row = list(map(int, input().split()))
    b.append(row)
b = numpy.array(b, dtype=int)

# Perform operations and print results
print(numpy.add(a, b))
print(numpy.subtract(a, b))
print(numpy.multiply(a, b))
# Use numpy.floor_divide for integer division as specified in the prompt
print(numpy.floor_divide(a, b))
print(numpy.mod(a, b))
print(numpy.power(a, b))
