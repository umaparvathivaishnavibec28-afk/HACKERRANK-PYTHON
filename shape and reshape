import numpy

# Read the input line of space-separated integers
input_line = input()

# Convert the space-separated string of integers into a 1D NumPy array of integers
# Use a generator expression to cast each string element to an integer
# and numpy.array() to create the array
my_array = numpy.array([int(x) for x in input_line.split()])

# Use the reshape function to change the 1D array into a 3x3 2D array
my_array = numpy.reshape(my_array, (3, 3))

# Print the resulting 3x3 NumPy array
print(my_array)
